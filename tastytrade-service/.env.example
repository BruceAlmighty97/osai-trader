# tastytrade SANDBOX (certification) credentials.
# Create a sandbox account at https://developer.tastytrade.com/sandbox/
# then copy this file to `.env` and fill in the values. NEVER commit .env.

# Environment: "sandbox" (api.cert.tastyworks.com) or "production" (api.tastyworks.com)
TT_ENV=sandbox

# Session auth (simplest for the spike) — your SANDBOX login + password
TT_USERNAME=
TT_PASSWORD=

# HTTP port for this service
PORT=3100

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=osaitrader
DB_PASSWORD=osaitrader_dev
DB_NAME=osaitrader

ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY_HERE>