# tastytrade SANDBOX (certification) credentials.
# Create a sandbox account at https://developer.tastytrade.com/sandbox/
# then copy this file to `.env` and fill in the values. NEVER commit .env.

# Environment: "sandbox" (api.cert.tastyworks.com) or "production" (api.tastyworks.com)
TT_ENV=sandbox

# Session auth (simplest for the spike) — your SANDBOX login + password
TT_USERNAME=
TT_PASSWORD=

# HTTP port for this service
PORT=3100

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=osaitrader
DB_PASSWORD=osaitrader_dev
DB_NAME=osaitrader

ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY_HERE>

# Reddit social-sentiment scanner (Phase A).
# Reddit KILLED self-service API keys in Nov 2025 (Responsible Builder Policy),
# so by default we use PUBLIC .json endpoints — NO credentials or approval needed
# (read-only, ~10 req/min, fine for a personal non-commercial scanner).
# A descriptive User-Agent is still recommended to avoid rate-limit blocks.
# Reddit's required format: <platform>:<app-id>:<version> (by /u/<username>)
REDDIT_USER_AGENT=nestjs:osaitrader-social:v0.1 (by /u/YOUR_USERNAME)
# Optional — comma-separated subreddits; defaults to the four below if unset
SOCIAL_SUBREDDITS=options,thetagang,wallstreetbets,optionswheel
# Optional — ms between Reddit requests (throttle). Default 2000 (public) / 400 (oauth).
# SOCIAL_REQUEST_DELAY_MS=2000
#
# OAuth mode (OPTIONAL): only if you get an approved app via Reddit's Developer
# Support form. Setting BOTH of these auto-switches to OAuth (higher limits).
# REDDIT_CLIENT_ID=
# REDDIT_SECRET=